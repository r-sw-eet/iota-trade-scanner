#!/usr/bin/env bash
# Pre-commit hook:
#  1. Blocks commits where package.json / package-lock.json changes leave
#     the lock file out of sync (failure mode that silently breaks CI's
#     `npm ci`, cf. commits d8f59c3, 2c6e892).
#  2. Runs coverage for api/ and/or website/ when source or test files in
#     that package are staged, then enforces the ratcheting baseline via
#     scripts/check-coverage.js. On improvement the baseline file is
#     updated and staged into the same commit.
#
# Install once with: `make hooks` (sets core.hooksPath to .githooks).

set -e

staged() {
  git diff --cached --name-only --diff-filter=ACMR | grep -E "^$1\$" >/dev/null
}

staged_under() {
  git diff --cached --name-only --diff-filter=ACMR | grep -E "^$1" >/dev/null
}

check_lockfile() {
  local dir="$1"
  if ! staged "$dir/package.json" && ! staged "$dir/package-lock.json"; then
    return 0
  fi

  echo "→ Verifying $dir lock file is in sync with package.json..."
  if ! ( cd "$dir" && npm ci --dry-run --no-audit --no-fund >/dev/null 2>&1 ); then
    cat <<EOF >&2

✗ $dir/package-lock.json is out of sync with package.json.
  CI will reject this with EUSAGE on \`npm ci\`.

  Fix:
    cd $dir && rm -rf node_modules package-lock.json && npm install
    git add $dir/package-lock.json
    git commit --amend --no-edit  # or re-run your commit

EOF
    exit 1
  fi
}

# check_coverage <dir> <cov-script-name> <staged-path-1> [<staged-path-2> ...]
#
# Runs `npm run <cov-script-name>` in <dir>, then the shared ratcheting
# check. Only fires when any of the passed staged-path prefixes are present
# in the staged file list. Stages an updated baseline file on improvement.
check_coverage() {
  local dir="$1"
  local cov_script="$2"
  shift 2

  local fired=0
  for p in "$@"; do
    if staged_under "$p"; then fired=1; break; fi
  done
  if [ "$fired" -eq 0 ]; then return 0; fi

  local log="/tmp/itsc-precommit-${dir}-cov.log"

  echo "→ Running $dir coverage..."
  if ! ( cd "$dir" && npm run "$cov_script" --silent >"$log" 2>&1 ); then
    cat <<EOF >&2

✗ $dir test suite failed during coverage run.

  Last 40 lines of output:

EOF
    tail -n 40 "$log" >&2
    cat <<EOF >&2

  Full log: $log
  To bypass just this run (not recommended): git commit --no-verify

EOF
    exit 1
  fi

  echo "→ Checking $dir coverage against baseline (ratcheting)..."
  if ! ( cd "$dir" && npm run cov:check --silent ); then
    cat <<EOF >&2

✗ $dir coverage regressed below $dir/.coverage-baseline.json.
  Restore coverage by adding tests, or edit the baseline if the drop is
  deliberate (e.g. dead code deleted legitimately).

  To bypass this check once: git commit --no-verify

EOF
    exit 1
  fi

  if ! git diff --quiet -- "$dir/.coverage-baseline.json"; then
    echo "→ $dir coverage baseline updated — staging $dir/.coverage-baseline.json"
    git add "$dir/.coverage-baseline.json"
  fi
}

check_lockfile api
check_lockfile website
check_coverage api     test:cov             api/src/     api/test/
check_coverage website test:unit:coverage   website/components/ website/composables/ website/pages/ website/tests/unit/
exit 0
