flowchart TB
    subgraph Registry["Our registry (code)"]
        PDef["ProjectDefinition<br/>• name, category, urls<br/>• match:<br/>&nbsp;&nbsp;– packageAddresses[]<br/>&nbsp;&nbsp;– all / any / exact module names<br/>&nbsp;&nbsp;– fingerprint { type, issuer, tag }"]
    end

    subgraph OnChain["IOTA L1 mainnet (Move, on-chain)"]
        Pkg[("Package<br/>0x… address (immutable)<br/>upgradeable to new address")]
        Mod["Module<br/>name: e.g. 'nft', 'ebl'<br/>lives inside a package"]
        Struct["Struct / Type<br/>e.g. 0x…::nft::NFT<br/>the 'schema' for objects"]
        Obj["Object<br/>id, owner, version,<br/>transactionDigest<br/>+ fields"]
        Tx["Transaction<br/>sender, gas, digest<br/>has effects + events"]
        Evt["Event<br/>sender, sendingModule,<br/>type, payload (json/bcs)<br/>filter via: emittingModule"]
    end

    PDef -. "identifies<br/>(3 match paths)" .-> Pkg

    Tx -- "publish (once)" --> Pkg
    Pkg -- "contains 1..N" --> Mod
    Mod -- "defines 0..N" --> Struct
    Struct -- "instantiated as" --> Obj
    Tx -- "creates / mutates /<br/>deletes" --> Obj
    Tx -- "emits 0..N" --> Evt
    Evt -- "emitted by" --> Mod
